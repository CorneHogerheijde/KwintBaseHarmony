{
  "name": "kwintbaseharmony-frontend-tests",
  "private": true,
  "scripts": {
    "dev": "dotnet run --project ./KwintBaseHarmony.Frontend.csproj --no-launch-profile --urls http://localhost:5051",
    "cy:open": "cypress open",
    "cy:run": "cypress run --browser electron",
    "test:e2e": "node ./scripts/run-cypress.js",
    "test:unit": "vitest run --config vitest.config.mjs",
    "test:unit:watch": "vitest --config vitest.config.mjs"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "cypress": "^14.3.3",
    "vitest": "^4.1.4"
  }
}
